---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Privacy Policy — Raven's Loft Web Design"
  noIndex={true}
>
  <Nav slot="header" />

  <section class="privacy">
    <div class="privacy-inner">
      <h1>Privacy Policy</h1>

      <p>
        We use essential cookies for site functionality and, with your
        consent, analytics cookies (Google Analytics 4) to understand
        site usage.
      </p>

      <h2>Cookies We Use</h2>
      <ul>
        <li>
          <strong>Essential:</strong> remembers your cookie preferences.
        </li>
        <li>
          <strong>Analytics (optional):</strong> GA4 to measure visits
          and page performance. IPs are anonymized.
        </li>
      </ul>

      <h2>Your Choices</h2>
      <p>
        You can accept or decline analytics cookies using the
        "Cookie settings" link in the footer at any time.
      </p>

      <h2>Contact</h2>
      <p>
        Questions? Email
        <a href="mailto:info@rlwebdesign.net">info@rlwebdesign.net</a>.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .privacy {
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    min-height: calc(100vh - 200px);
  }

  .privacy-inner {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .privacy-inner h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--color-heading);
  }

  .privacy-inner h2 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-heading);
    margin-top: 0.5rem;
  }

  .privacy-inner p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text);
    line-height: 1.65;
  }

  .privacy-inner ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-left: 1.25rem;
  }

  .privacy-inner li {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text);
    line-height: 1.65;
    list-style: disc;
  }

  .privacy-inner strong {
    color: var(--color-heading);
  }

  .privacy-inner a {
    color: var(--color-accent);
    transition: color 200ms ease;
  }

  .privacy-inner a:hover {
    color: var(--color-heading);
  }
</style>