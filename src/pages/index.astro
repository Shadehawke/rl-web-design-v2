---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SocialSidebar from '../components/SocialSidebar.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout>
  <Nav slot="header" />
  <SocialSidebar />

  <!-- HERO -->
  <section id="home" class="hero">
    <!-- Atmospheric background accents -->
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="hero-inner">
      <!-- Photo -->
      <div class="hero-photo">
        <img
          src="/images/Headshot.webp"
          alt="Portrait of Shawn Spitaleri, Web Designer at Raven's Loft"
          width="320"
          height="400"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="headshot"
        />
      </div>

      <!-- Copy -->
      <div class="hero-content">
        <span class="hero-eyebrow">Raven's Loft Web Design</span>

        <h1 class="hero-heading">
          Most beautiful websites are broken.
          <em>I build ones that aren't.</em>
        </h1>

        <p class="hero-lede">
          Dark, atmospheric sites built with rigorous accessibility and real
          performance — because gothic design and WCAG compliance aren't opposites.
        </p>

        <p class="hero-note">
          A division of <a href="https://obscurameridian.com" target="_blank" rel="noopener noreferrer">Obscura Meridian Co.</a>
        </p>

        <div class="hero-ctas">
          <a href="#contact" class="btn btn-primary">Request a Quote</a>
          <a href="#work" class="btn btn-ghost">View Work</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section id="problem" class="problem">
    <div class="problem-inner fade-in">
      <h2>The web has an accessibility problem.</h2>

      <p>
        87% of websites have detectable accessibility issues. The number is
        higher for design-forward sites — dark themes with poor contrast,
        decorative fonts on body copy, no keyboard navigation, animations
        that ignore <code>prefers-reduced-motion</code>.
      </p>

      <p>
        Atmosphere and accessibility are treated as trade-offs. They aren't.
        Every site I build is designed to <strong>look intentional and work
        for everyone</strong> — keyboard users, screen readers, people on
        slow connections, and clients who want a beautiful site that actually loads.
      </p>

      <!-- Proof pills -->
      <ul class="problem-pills" aria-label="Accessibility commitments">
        <li>
          <span class="fa-solid fa-universal-access" aria-hidden="true"></span>
          WCAG-informed markup
        </li>
        <li>
          <span class="fa-solid fa-keyboard" aria-hidden="true"></span>
          Keyboard navigable
        </li>
        <li>
          <span class="fa-solid fa-gauge-high" aria-hidden="true"></span>
          Reduced-motion aware
        </li>
        <li>
          <span class="fa-solid fa-eye" aria-hidden="true"></span>
          Real contrast ratios
        </li>
      </ul>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about">
    <div class="about-inner">
      <div class="about-text fade-in">
        <h2>About</h2>

        <p>
          At Raven's Loft Web Design, I believe every website should be more
          than a collection of pages — it should be an experience where
          creativity, clarity, and identity converge.
        </p>

        <p>
          My approach is rooted in <strong>balance</strong>: form and function,
          art and accessibility, imagination and usability. I craft sites that
          are visually striking yet easy to navigate, designed to resonate with
          audiences while reflecting the unique character of the brand they
          represent.
        </p>

        <p>
          That means dark themes with contrast ratios that actually pass.
          Animations that respect motion preferences. Keyboard navigation that
          works. Performance that doesn't sacrifice atmosphere to get there.
        </p>
      </div>

      <div class="about-values fade-in" role="note" aria-label="Core values">
        <h3>What I Value</h3>
        <ul class="values-list">
          <li>
            <span class="fa-solid fa-universal-access" aria-hidden="true"></span>
            Accessibility
          </li>
          <li>
            <span class="fa-solid fa-paintbrush" aria-hidden="true"></span>
            Creativity
          </li>
          <li>
            <span class="fa-solid fa-scale-balanced" aria-hidden="true"></span>
            Balance
          </li>
          <li>
            <span class="fa-solid fa-fingerprint" aria-hidden="true"></span>
            Identity
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section id="capabilities" class="capabilities">
    <div class="capabilities-inner">
      <div class="capabilities-heading fade-in">
        <h2>What I Build</h2>
      </div>

      <div class="capabilities-grid">
        <div class="capability-card fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="fa-solid fa-pen-ruler card-icon" aria-hidden="true"></span>
          <h3>Design + Build</h3>
          <p>
            Responsive layouts, modern UI, and clean implementation —
            designed and built together, not handed off between
            disconnected stages.
          </p>
        </div>

        <div class="capability-card fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="fa-solid fa-gauge-high card-icon" aria-hidden="true"></span>
          <h3>Performance</h3>
          <p>
            Fast load times, optimized assets, and Lighthouse-minded
            builds focused on real-world performance — not just scores.
          </p>
        </div>

        <div class="capability-card fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="fa-solid fa-universal-access card-icon" aria-hidden="true"></span>
          <h3>Accessibility</h3>
          <p>
            Semantic HTML, keyboard navigation, readable contrast, and
            focus states built in from the start — not bolted on after
            launch.
          </p>
        </div>

        <div class="capability-card fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="fa-solid fa-magnifying-glass-chart card-icon" aria-hidden="true"></span>
          <h3>SEO Foundations</h3>
          <p>
            Clean structure, metadata, structured data, and indexing
            hygiene that gives your site a solid technical baseline from
            day one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SELECTED WORK -->
  <section id="work" class="work">
    <div class="work-inner">
      <div class="work-heading fade-in">
        <h2>Selected Work</h2>
        <p class="work-lede">
          A focused selection of recent builds — designed for clarity,
          speed, and clean delivery.
        </p>
      </div>

      <div class="work-grid">
        {projects.map(project => (
          <article
            class="project-card fade-in"
            aria-label={project.data.title}
          >
            <!-- Screenshot -->
            <div class="card-image-wrap">
              <img
                src={project.data.image}
                alt={project.data.imageAlt}
                width="720"
                height="450"
                loading="lazy"
                decoding="async"
              />
              {project.data.comingSoon && (
                <span class="coming-soon-badge">Coming Soon</span>
              )}
            </div>

            <!-- Title -->
            <div class="card-title-wrap">
              <h3>{project.data.title}</h3>
              <p class="card-tagline">{project.data.tagline}</p>
            </div>

            <!-- Meta pills -->
            <div class="card-meta">
              <span class="meta-pill">
                <strong>Role:</strong> {project.data.role}
              </span>
              <span class="meta-pill">
                <strong>Focus:</strong> {project.data.focus}
              </span>
              <span class="meta-pill">
                <strong>Scope:</strong> {project.data.scope}
              </span>
            </div>

            <!-- Case study body -->
            <div class="card-case-study">
              <div class="case-study-row">
                <span class="case-label">Problem</span>
                <p>{project.data.problem}</p>
              </div>
              <div class="case-study-row">
                <span class="case-label">Solution</span>
                <p>{project.data.solution}</p>
              </div>
              <div class="case-study-row">
                <span class="case-label">Result</span>
                <p>{project.data.result}</p>
              </div>
            </div>

            <!-- CTA -->
            <div class="card-cta">
              {project.data.comingSoon ? (
                <span class="btn btn-disabled" aria-disabled="true">
                  Site Coming Soon
                </span>
              ) : (
                <a
                  href={project.data.url ?? '#'}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary"
                >
                  View Site
                  <span class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></span>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process" class="process">
    <div class="process-inner">
      <div class="process-heading fade-in">
        <h2>How It Works</h2>
        <p class="process-sub">
          A straightforward build process designed for clarity,
          momentum, and clean delivery.
        </p>
      </div>

      <ol class="process-steps">
        <li class="process-step fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="step-label">01</span>
          <div class="step-body">
            <h3>Discovery</h3>
            <p>
              Goals, audience, content, and constraints — defined up
              front so nothing gets reworked later.
            </p>
          </div>
        </li>

        <li class="process-step fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="step-label">02</span>
          <div class="step-body">
            <h3>Design</h3>
            <p>
              Structure and visuals aligned to your brand and conversion
              goals, reviewed before a line of code is written.
            </p>
          </div>
        </li>

        <li class="process-step fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="step-label">03</span>
          <div class="step-body">
            <h3>Build</h3>
            <p>
              Responsive implementation, performance-minded,
              accessibility included — not added after.
            </p>
          </div>
        </li>

        <li class="process-step fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="step-label">04</span>
          <div class="step-body">
            <h3>Launch + Support</h3>
            <p>
              Go live with confidence — plus handoff documentation,
              post-launch fixes, and optional ongoing care.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="services">
    <div class="services-inner">
      <div class="services-heading fade-in">
        <h2>Ways to Work Together</h2>
        <p class="services-lede">
          Clear, flexible options depending on what you need built —
          or what needs to be cleaned up.
        </p>
      </div>

      <div class="services-grid">
        <!-- Starter Site -->
        <div class="service-card fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <h3>Starter Site</h3>
          <p class="service-desc">
            A clean, modern site for a focused offer — ideal when you
            want to look credible fast.
          </p>
          <ul class="service-list">
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              1–3 core pages
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Mobile-first layout
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Basic SEO + metadata
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Accessibility-minded structure
            </li>
          </ul>
        </div>

        <!-- Business Site -->
        <div class="service-card service-card--featured fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <span class="featured-badge">Most Common</span>
          <h3>Business Site</h3>
          <p class="service-desc">
            A scalable multi-page build with clear navigation, content
            structure, and room to grow.
          </p>
          <ul class="service-list">
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Multi-page architecture
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Content + section strategy
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Conversion-focused layout
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Performance and polish pass
            </li>
          </ul>
        </div>

        <!-- Refactor -->
        <div class="service-card fade-in">
          <div class="card-accent-bar" aria-hidden="true"></div>
          <h3>Refactor + Improve</h3>
          <p class="service-desc">
            For existing sites that feel dated, slow, or messy — tighten
            the system without rebuilding everything.
          </p>
          <ul class="service-list">
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Layout and CSS cleanup
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Accessibility fixes
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Performance optimization
            </li>
            <li>
              <span class="fa-solid fa-check" aria-hidden="true"></span>
              Consistency + component polish
            </li>
          </ul>
        </div>
      </div>

      <!-- CTA row -->
      <div class="services-cta fade-in">
        <a href="#contact" class="btn btn-primary">Start a Project</a>
        <a href="#work" class="btn btn-ghost">See Examples</a>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact">
    <div class="contact-inner">
      <div class="contact-heading fade-in">
        <h2>Commission a Build</h2>
        <p class="contact-lede">
          Tell me what you're building — or fixing. I'll reply within
          1–2 business days with a clear recommendation and next steps.
        </p>
      </div>

      <!-- Meta strip -->
      <div class="contact-meta">
        <div class="meta-item fade-in">
          <h3>Best for</h3>
          <p>
            Small business sites, creator portfolios, landing pages,
            and accessibility refactors.
          </p>
        </div>
        <div class="meta-item fade-in">
          <h3>What happens next</h3>
          <p>
            A quick review of your goals, then a short follow-up with
            scope and options — no hard sell.
          </p>
        </div>
        <div class="meta-item fade-in">
          <h3>Currently available</h3>
          <p>
            Accepting new projects. Response within 1–2 business days.
          </p>
        </div>
      </div>

      <!-- Form -->
      <form
        class="contact-form fade-in"
        action="https://formsubmit.co/b418b3b97a7c15a4d6d41f426d0616e0"
        method="POST"
        novalidate
        id="contact-form"
      >
        <!-- FormSubmit config -->
        <input type="hidden" name="_subject" value="New Inquiry — Raven's Loft Web Design" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://rlwebdesign.net/thanks" />
        <!-- Honeypot -->
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <!-- Project type selector -->
        <fieldset class="field-group">
          <legend>Project type</legend>
          <div class="type-options" role="group">
            <label class="type-option">
              <input type="radio" name="project_type" value="New site" checked />
              <span>New site</span>
            </label>
            <label class="type-option">
              <input type="radio" name="project_type" value="Refactor" />
              <span>Refactor</span>
            </label>
            <label class="type-option">
              <input type="radio" name="project_type" value="Accessibility audit" />
              <span>Accessibility audit</span>
            </label>
            <label class="type-option">
              <input type="radio" name="project_type" value="Not sure yet" />
              <span>Not sure yet</span>
            </label>
          </div>
        </fieldset>

        <!-- Name -->
        <div class="field">
          <label for="name">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            required
          />
          <p class="field-error" aria-live="polite"></p>
        </div>

        <!-- Email -->
        <div class="field">
          <label for="email">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            inputmode="email"
            autocomplete="email"
            required
          />
          <p class="field-error" aria-live="polite"></p>
        </div>

        <!-- Message -->
        <div class="field">
          <label for="message">Tell me about your project</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            minlength="10"
            required
            placeholder="What do you need built or improved? Timeline, goals, and any links help."
          ></textarea>
          <p class="field-error" aria-live="polite"></p>
        </div>

        <button class="btn btn-primary" type="submit" id="contact-submit">
          Start the Conversation
        </button>

        <p class="submit-status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <Footer slot="footer" />

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (form) {
      const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
      const statusEl = form.querySelector('.submit-status') as HTMLElement | null;
      const fields = form.querySelectorAll('.field');

      form.addEventListener('submit', (e) => {
        let valid = form.checkValidity();

        fields.forEach(f => {
          const input = f.querySelector('input, textarea') as HTMLInputElement | HTMLTextAreaElement | null;
          const err = f.querySelector('.field-error') as HTMLElement | null;
          if (!input || !err) return;
          err.textContent = input.validity.valid ? '' : input.validationMessage;
        });

        if (!valid) {
          e.preventDefault();
          if (statusEl) statusEl.textContent = 'Please fix the highlighted fields.';
          return;
        }

        if (submitBtn) submitBtn.setAttribute('disabled', 'true');
        if (statusEl) statusEl.textContent = 'Sending…';
      });

      form.addEventListener('input', (e) => {
        const field = (e.target as HTMLElement).closest('.field');
        if (!field) return;
        const input = field.querySelector('input, textarea') as HTMLInputElement | null;
        const err = field.querySelector('.field-error') as HTMLElement | null;
        if (input && err) err.textContent = '';
        if (statusEl) statusEl.textContent = '';
      });
    }
  </script>
</Layout>

<style>
  /* ── Hero ───────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(600px 400px at 80% 10%, rgba(163,29,47,0.04), transparent 60%),
      radial-gradient(500px 300px at 10% 80%, rgba(163,29,47,0.03), transparent 60%);
  }

  .hero-inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }

  /* Photo */
  .hero-photo {
    display: flex;
    justify-content: center;
  }

  .headshot {
    width: 100%;
    max-width: 300px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 30px rgba(0,0,0,0.45);
    object-fit: cover;
  }

  /* Copy */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-content {
      text-align: left;
    }
  }

  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid rgba(163,29,47,0.3);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    align-self: center;
  }

  @media (min-width: 768px) {
    .hero-eyebrow {
      align-self: flex-start;
    }
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.25rem);
    color: var(--color-heading);
    line-height: 1.08;
    max-width: 20ch;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .hero-heading {
      margin: 0;
    }
  }

  .hero-heading em {
    display: block;
    font-style: italic;
    color: var(--color-accent);
  }

  .hero-lede {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text);
    line-height: 1.6;
    max-width: 55ch;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .hero-lede {
      margin: 0;
    }
  }

  .hero-note {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .hero-note a {
    color: var(--color-text-muted);
    transition: color 200ms ease;
  }

  .hero-note a:hover {
    color: var(--color-heading);
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .hero-ctas {
      justify-content: flex-start;
    }
  }

  /* ── Buttons ────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.5rem;
    border-radius: 14px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: transform 150ms ease, box-shadow 150ms ease;
    border: 1px solid transparent;
  }

  .btn-primary {
    color: var(--color-heading);
    border-color: var(--color-accent);
    background: rgba(163,29,47,0.2);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(163,29,47,0.35);
  }

  .btn-ghost {
    color: var(--color-heading);
    border-color: var(--color-border);
    background: transparent;
  }

  .btn-ghost:hover,
  .btn-ghost:focus-visible {
    transform: translateY(-1px);
    border-color: var(--color-heading);
  }

  /* ── Problem ────────────────────────────────────────────────────── */
  .problem {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
    text-align: center;
  }

  .problem-inner {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .problem h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    color: var(--color-heading);
  }

  .problem p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text);
    line-height: 1.65;
    max-width: 60ch;
  }

  .problem strong {
    color: var(--color-heading);
  }

  .problem code {
    font-size: 0.9em;
    color: rgba(163,29,47,0.9);
    background: rgba(255,255,255,0.05);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-family: monospace;
  }

  .problem-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
  }

  .problem-pills li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(255,255,255,0.02);
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .problem-pills li .fa-solid {
    color: var(--color-accent);
  }

  /* ── About ──────────────────────────────────────────────────────── */
  .about {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .about::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(1200px 400px at 80% 10%, rgba(255,255,255,0.03), transparent 60%),
      radial-gradient(700px 260px at 10% 80%, rgba(163,29,47,0.06), transparent 60%);
  }

  .about-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
    text-align: center;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-text h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    color: var(--color-heading);
  }

  .about-text p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text);
    line-height: 1.65;
  }

  .about-text strong {
    color: var(--color-heading);
  }

  .about-values {
    width: 100%;
    max-width: 680px;
    padding: 1.5rem 2rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
    box-shadow: 0 10px 30px rgba(0,0,0,0.35);
    transition: border-color 220ms ease, box-shadow 220ms ease;
  }

  .about-values:hover {
    border-color: rgba(163,29,47,0.4);
    box-shadow: 0 14px 36px rgba(163,29,47,0.18);
  }

  .about-values h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-heading);
    margin-bottom: 1rem;
  }

  .values-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .values-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text);
  }

  .values-list li .fa-solid {
    color: var(--color-accent);
  }

  /* ── Capabilities ───────────────────────────────────────────────── */
  .capabilities {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
  }

  .capabilities-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .capabilities-heading {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .capabilities-heading h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    color: var(--color-heading);
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .capabilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .capabilities-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .capability-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0));
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    transition: transform 160ms ease, box-shadow 200ms ease, border-color 120ms ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .capability-card:hover {
    transform: translateY(-2px);
    border-color: rgba(163,29,47,0.35);
    box-shadow: 0 14px 36px rgba(163,29,47,0.18);
  }

  .card-accent-bar {
    height: 2px;
    width: 48px;
    background: rgba(163,29,47,0.7);
    border-radius: 999px;
  }

  .card-icon {
    color: var(--color-accent);
    font-size: 1.25rem;
  }

  .capability-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    color: var(--color-heading);
    margin: 0;
  }

  .capability-card p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
    opacity: 0.95;
  }

  /* ── Selected Work ──────────────────────────────────────────────── */
  .work {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
    text-align: center;
  }

  .work-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .work-heading {
    margin-bottom: 2.5rem;
  }

  .work-heading h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    color: var(--color-heading);
    margin-bottom: 0.75rem;
  }

  .work-lede {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 55ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 860px) {
    .work-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1120px) {
    .work-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* Card */
  .project-card {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    gap: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    overflow: hidden;
    transition: transform 160ms ease, box-shadow 200ms ease, border-color 100ms ease;
    text-align: left;
  }

  .project-card:hover {
    transform: translateY(-2px);
    border-color: rgba(163,29,47,0.35);
    box-shadow: 0 14px 36px rgba(163,29,47,0.18);
  }

  /* Image */
  .card-image-wrap {
    position: relative;
  }

  .card-image-wrap img {
  display: block;
  width: 100%;
  height: 250px;
  object-fit: contain;
  border-bottom: 1px solid var(--color-border);
  background: #0f0f12;
  padding: 1rem;
  }

  .coming-soon-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-heading);
    background: rgba(163,29,47,0.85);
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(163,29,47,0.5);
  }

  /* Title */
  .card-title-wrap {
    padding: 0 1.25rem;
  }

  .card-title-wrap h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
    color: var(--color-heading);
    margin-bottom: 0.35rem;
  }

  .card-tagline {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Meta pills */
  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0 1.25rem;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: rgba(13,13,16,0.8);
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .meta-pill strong {
    color: var(--color-heading);
  }

  /* Case study */
  .card-case-study {
    padding: 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .case-study-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem;
    align-items: baseline;
  }

  .case-label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-heading);
    padding-top: 0.15rem;
  }

  .card-case-study p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  /* CTA */
  .card-cta {
    padding: 0 1.25rem 1.25rem;
  }

  .btn-disabled {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.5rem;
    border-radius: 14px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    background: transparent;
    cursor: default;
    opacity: 0.6;
  }

  .btn .fa-solid {
    margin-left: 0.5rem;
    font-size: 0.875rem;
  }

  /* ── Process ────────────────────────────────────────────────────── */
  .process {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
  }

  .process-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .process-heading {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .process-heading h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    color: var(--color-heading);
    margin-bottom: 0.75rem;
  }

  .process-sub {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 55ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 640px) {
    .process-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .process-steps {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .process-step {
    position: relative;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0));
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    transition: transform 160ms ease, box-shadow 200ms ease, border-color 120ms ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .process-step:hover {
    transform: translateY(-2px);
    border-color: rgba(163,29,47,0.35);
    box-shadow: 0 14px 36px rgba(163,29,47,0.18);
  }

  .step-label {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-heading);
    opacity: 0.75;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: rgba(13,13,16,0.8);
  }

  .step-body {
    padding-right: 2.5rem;
  }

  .step-body h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    color: var(--color-heading);
    margin-bottom: 0.5rem;
  }

  .step-body p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
    opacity: 0.95;
  }

  /* ── Services ───────────────────────────────────────────────────── */
  .services {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
    text-align: center;
  }

  .services-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .services-heading {
    margin-bottom: 2.5rem;
  }

  .services-heading h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    color: var(--color-heading);
    margin-bottom: 0.75rem;
  }

  .services-lede {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 55ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    text-align: left;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .service-card {
    position: relative;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0));
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    transition: transform 160ms ease, box-shadow 200ms ease, border-color 120ms ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-card:hover {
    transform: translateY(-2px);
    border-color: rgba(163,29,47,0.35);
    box-shadow: 0 14px 36px rgba(163,29,47,0.18);
  }

  .service-card--featured {
    border-color: rgba(163,29,47,0.5);
  }

  .service-card--featured:hover {
    border-color: var(--color-accent);
  }

  .featured-badge {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid rgba(163,29,47,0.4);
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
  }

  .service-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    color: var(--color-heading);
    margin: 0;
  }

  .service-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
    opacity: 0.95;
  }

  .service-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
    margin-top: auto;
  }

  .service-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
  }

  .service-list li .fa-solid {
    color: var(--color-accent);
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .services-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Contact ────────────────────────────────────────────────────── */
  .contact {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(3rem, 8vh, 5rem) 1.5rem;
    text-align: center;
  }

  .contact-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-heading {
    margin-bottom: 2.5rem;
  }

  .contact-heading h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    color: var(--color-heading);
    margin-bottom: 0.75rem;
  }

  .contact-lede {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 55ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Meta strip */
  .contact-meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto 2.5rem;
    text-align: left;
  }

  @media (min-width: 768px) {
    .contact-meta {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .meta-item {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0));
    box-shadow: 0 8px 24px rgba(0,0,0,0.22);
  }

  .meta-item h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-heading);
    margin-bottom: 0.5rem;
  }

  .meta-item p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  /* Form */
  .contact-form {
    max-width: 680px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
    padding: 2rem 2rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
    box-shadow: 0 10px 30px rgba(0,0,0,0.35);
    text-align: left;
  }

  /* Project type selector */
  .field-group {
    border: none;
    margin: 0;
    padding: 0;
  }

  .field-group legend {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-heading);
    margin-bottom: 0.75rem;
  }

  .type-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .type-option {
    display: flex;
    align-items: center;
    cursor: pointer;
  }

  .type-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .type-option span {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transition: border-color 150ms ease, background 150ms ease, color 150ms ease;
    user-select: none;
  }

  .type-option input[type="radio"]:checked + span {
    border-color: var(--color-accent);
    background: rgba(163,29,47,0.15);
    color: var(--color-heading);
  }

  .type-option:hover span {
    border-color: rgba(163,29,47,0.5);
  }

  .type-option input[type="radio"]:focus-visible + span {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 999px;
  }

  /* Fields */
  .field {
    display: grid;
    gap: 0.5rem;
  }

  .field label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-heading);
  }

  .field input,
  .field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: rgba(255,255,255,0.02);
    color: var(--color-heading);
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.5;
    transition: border-color 200ms ease, background 200ms ease;
  }

  .field input:focus,
  .field textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-color: var(--color-accent);
    background: rgba(255,255,255,0.05);
  }

  .field textarea {
    resize: vertical;
    min-height: 140px;
  }

  .field-error {
    min-height: 1em;
    font-family: var(--font-body);
